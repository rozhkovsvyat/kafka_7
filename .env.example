# =============================================================
# Аналитическая платформа для маркетплейса — конфигурация
# Скопировать в .env: copy .env.example .env
# =============================================================

# --- YC Kafka (основной кластер) ---
BOOTSTRAP_SERVER=<hostname>.mdb.yandexcloud.net:9091
KAFKA_USER=admin
KAFKA_PASS=<пароль_kafka>

# --- Сервисные аккаунты (имена должны совпадать в ACL, Docker, приложениях) ---
KAFKA_USER_SHOP=shop-producer
KAFKA_USER_STREAMS=streams-app
KAFKA_USER_CONNECT=kafka-connect
KAFKA_USER_MIRROR=mirrormaker
KAFKA_USER_ANALYTICS=analytics
KAFKA_USER_CLIENT_PRODUCER=client-producer
KAFKA_USER_CLIENT_CONSUMER=client-consumer

# Пароль для сервисных аккаунтов
KAFKA_PASS_APP=<пароль_сервисных_аккаунтов>

# --- Java KeyStore (TLS truststore) ---
CERT_DIR=%USERPROFILE%\.kafka
CERT_URL=https://storage.yandexcloud.net/cloud-certs/CA.pem
STORE_PASS=<пароль_jks>

# --- Schema Registry (YC) ---
SCHEMA_REGISTRY_URL=https://<hostname>.mdb.yandexcloud.net:443

# --- Топики ---
TOPIC_SHOP_PRODUCTS=shop-products
TOPIC_CLIENT_QUERIES=client-queries
TOPIC_PRODUCTS_FILTERED=products-filtered
TOPIC_RECOMMENDATIONS=recommendations

# --- Local Docker Kafka (второй кластер, Mirror) ---
LOCAL_KAFKA_BOOTSTRAP=localhost:29092,localhost:29093,localhost:29094

# --- HDFS (локальный Docker) ---
HDFS_NAMENODE_URL=http://localhost:9870

# --- Spark (локальный Docker) ---
SPARK_MASTER_URL=spark://localhost:7077

# --- Kafka Connect (локальный Docker) ---
KAFKA_CONNECT_URL=http://localhost:8083

# --- Grafana (локальный Docker) ---
GRAFANA_USER=admin
GRAFANA_PASS=admin

# --- Telegram Alertmanager ---
TELEGRAM_BOT_TOKEN=<telegram_bot_token>
TELEGRAM_CHAT_ID=<telegram_chat_id>
